{
    "name": "latinshop/latinshop",
    "description": "Latin Shop - Plataforma Lords Mobile",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "phpmailer/phpmailer": "^7.1",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {},
    "autoload-dev": {
        "psr-4": {
            "LatinShop\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":          "phpunit --configuration phpunit.xml",
        "test-unit":     "phpunit --configuration phpunit.xml --testsuite Unit",
        "test-coverage": "phpunit --configuration phpunit.xml --coverage-html coverage/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
