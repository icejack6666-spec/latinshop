<?xml version="1.0"?>
<!--
    phpcs.xml — Latin Shop
    PSR-12 con excepciones razonables para el proyecto
-->
<ruleset name="LatinShop">
    <description>PSR-12 + reglas personalizadas Latin Shop</description>

    <file>includes</file>
    <file>config</file>
    <file>pages</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/frontend/*</exclude-pattern>
    <exclude-pattern>*/includes/phpmailer/*</exclude-pattern>

    <arg name="extensions" value="php"/>

    <arg name="colors"/>
    <arg value="p"/>

    <rule ref="PSR12"/>

    <rule ref="PSR12.Files.FileHeader">
        <exclude-pattern>*/pages/*</exclude-pattern>
    </rule>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="160"/>
        </properties>
    </rule>
</ruleset>
